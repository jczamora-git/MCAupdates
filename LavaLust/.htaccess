AddDefaultCharset UTF-8

# Allow public PWA manifests under /ui while keeping other JSON files protected.
SetEnvIfNoCase Request_URI "^/ui/(manifest\.json|manifest\.webmanifest)$" allow_public_manifest=1

<IfModule mod_rewrite.c>
    RewriteEngine On

    # --------------------------------------------------
    # Allow index.php
    <Files "index.php">
        Require all granted
    </Files>

    # --------------------------------------------------
    # Deny access to sensitive directories
    RedirectMatch 403 ^/(app|scheme|console|runtime)/

    # --------------------------------------------------
    # Deny access to sensitive files.
    # Exception: /ui/manifest.json and /ui/manifest.webmanifest must stay publicly readable.
    <FilesMatch "\.(env|json|xml|log|md|lock|git|ini|bak|sql)$">
        <RequireAny>
            Require env allow_public_manifest
            Require all denied
        </RequireAny>
    </FilesMatch>

    # --------------------------------------------------
    # Prevent directory browsing
    Options -Indexes

    # --------------------------------------------------
    # Default landing page: send root URL to frontend auth route
    RewriteRule ^$ /auth [R=302,L]

    # --------------------------------------------------
    # Public share-image alias without /ui prefix
    RewriteRule ^register-cover\.png$ /ui/register-cover.png [L,NC]
    RewriteRule ^dev-cover\.png$ /ui/dev-cover.png [L,NC]
    RewriteRule ^dev-icon\.png$ /ui/dev-icon.png [L,NC]

    # --------------------------------------------------
    # Predictive API alias (maps /predictive-api to uploaded ML API folder)
    RewriteRule ^predictive-api(?:/(.*))?$ /ml/predictive_api/api/$1 [QSA,L,NC]

    # --------------------------------------------------
    # Keep existing files/folders accessible as-is (includes /ui assets and backend files)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # --------------------------------------------------
    # Keep backend API on PHP router
    RewriteRule ^api(?:/(.*))?$ index.php/api/$1 [QSA,L]

    # --------------------------------------------------
    # Frontend SPA fallback: serve /ui/index.html without changing URL
    RewriteRule ^ /ui/index.html [QSA,L]
</IfModule>
